{
  "name": "phone_recognizer",
  "entity_type": "PHONE_NUMBER",
  "version": "1.0.0",
  "patterns": [
    {
      "name": "phone_with_country_code",
      "regex": "(?:\\+?\\d{1,3}[\\-\\s.]?)?\\(?\\d{2,4}\\)?[\\-\\s.]?\\d{3,4}[\\-\\s.]?\\d{3,4}",
      "score": 0.4
    },
    {
      "name": "phone_us_format",
      "regex": "\\(?\\d{3}\\)?[\\-\\s.]?\\d{3}[\\-\\s.]?\\d{4}",
      "score": 0.4
    }
  ],
  "context_words": ["phone", "telephone", "tel", "mobile", "cell", "call", "fax", "电话", "手机", "電話"],
  "context_score_boost": 0.4,
  "supported_languages": null
}
