{
  "name": "credit_card_recognizer",
  "entity_type": "CREDIT_CARD",
  "version": "1.1.0",
  "note": "Regex aligned with Microsoft Presidio (MIT License)",
  "patterns": [
    {
      "name": "all_credit_cards",
      "regex": "\\b(?:4\\d{3}|5[0-5]\\d{2}|6\\d{3}|1\\d{3}|3\\d{3})[- ]?\\d{3,4}[- ]?\\d{3,4}[- ]?\\d{3,5}\\b",
      "score": 0.3
    }
  ],
  "context_words": ["credit", "card", "visa", "mastercard", "cc", "amex", "discover", "jcb", "diners", "maestro", "信用卡", "银行卡"],
  "context_score_boost": 0.4,
  "validators": ["luhn"],
  "supported_languages": null
}
