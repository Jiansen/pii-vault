{
  "name": "email_recognizer",
  "entity_type": "EMAIL_ADDRESS",
  "version": "1.1.0",
  "note": "Regex aligned with Microsoft Presidio (MIT License)",
  "patterns": [
    {
      "name": "email_presidio",
      "regex": "\\b(?:(?:[!#$%&'*+\\-/=?^_`{|}~\\w])|(?:[!#$%&'*+\\-/=?^_`{|}~\\w][!#$%&'*+\\-/=?^_`{|}~.\\w]{0,}[!#$%&'*+\\-/=?^_`{|}~\\w]))@\\w+(?:[\\-.]\\w+)*\\.\\w+(?:[\\-.]\\w+)*\\b",
      "score": 0.5
    }
  ],
  "context_words": ["email", "e-mail", "mail", "address", "邮箱", "メール"],
  "context_score_boost": 0.4,
  "supported_languages": null
}
