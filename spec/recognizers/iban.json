{
  "name": "iban_recognizer",
  "entity_type": "IBAN_CODE",
  "version": "1.0.0",
  "patterns": [
    {
      "name": "iban_generic",
      "regex": "\\b[A-Z]{2}\\d{2}[\\s]?[A-Z0-9]{4}[\\s]?(?:[A-Z0-9]{4}[\\s]?){2,7}[A-Z0-9]{1,4}\\b",
      "score": 0.4
    }
  ],
  "context_words": ["iban", "bank", "account", "transfer", "wire"],
  "context_score_boost": 0.4,
  "validators": ["iban_checksum"],
  "supported_languages": null
}
