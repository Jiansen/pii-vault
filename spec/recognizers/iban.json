{
  "name": "iban_recognizer",
  "entity_type": "IBAN_CODE",
  "version": "1.0.0",
  "note": "IBAN detection with Mod 97-10 checksum. Regex matches generic IBAN format; per-country format validation can be added as Phase 2.",
  "patterns": [
    {
      "name": "iban_spaced",
      "regex": "\\b[A-Z]{2}\\d{2}[ ]?[A-Za-z0-9]{4}[ ]?(?:[A-Za-z0-9]{4}[ ]?){1,7}[A-Za-z0-9]{1,4}\\b",
      "score": 0.5
    }
  ],
  "context_words": ["iban", "international bank account", "bank account", "swift", "bic", "sepa", "bankverbindung", "kontonummer", "compte bancaire", "cuenta bancaria", "银行账号"],
  "context_score_boost": 0.4,
  "validators": ["iban"],
  "supported_languages": null
}
