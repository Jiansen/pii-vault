{
  "name": "crypto_recognizer",
  "entity_type": "CRYPTO",
  "version": "1.1.0",
  "note": "Regex aligned with Microsoft Presidio (MIT License)",
  "patterns": [
    {
      "name": "bitcoin_all",
      "regex": "\\b(?:bc1|[13])[a-zA-HJ-NP-Z0-9]{25,59}\\b",
      "score": 0.5
    },
    {
      "name": "ethereum",
      "regex": "\\b0x[0-9a-fA-F]{40}\\b",
      "score": 0.5
    }
  ],
  "context_words": ["wallet", "btc", "bitcoin", "crypto", "ethereum", "eth", "blockchain"],
  "context_score_boost": 0.3,
  "supported_languages": null
}
